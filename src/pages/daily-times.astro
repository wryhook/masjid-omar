---
import { siteDetails } from '@/data/siteDetails';
import prayerTimesData from '@/data/prayer-times-feb-2026.json';

const PRAYER_KEYS = ['fajr', 'sunrise', 'dhuhr', 'asr', 'maghrib', 'isha'] as const;
const PRAYER_NAMES: Record<(typeof PRAYER_KEYS)[number], string> = {
  fajr: 'Fajr',
  sunrise: 'Sunrise',
  dhuhr: 'Dhuhr',
  asr: 'Asr',
  maghrib: 'Maghrib',
  isha: 'Isha',
};

function to24h(timeStr: string, key: string): string {
  const [h, m] = timeStr.split(':').map(Number);
  if (['asr', 'maghrib', 'isha'].includes(key) && h >= 1 && h <= 7) {
    return `${h + 12}:${String(m).padStart(2, '0')}`;
  }
  return timeStr;
}

type DayData = Record<string, { start: string; iqama?: string }>;

function dayDataToPrayerTimes(dayData: DayData): { name: string; time: string; iqama: string | null; isNext: boolean }[] {
  return PRAYER_KEYS.map((key) => {
    const slot = dayData[key];
    if (!slot) return { name: PRAYER_NAMES[key], time: '00:00', iqama: null, isNext: false };
    const time = to24h(slot.start, key);
    const iqama = slot.iqama ? to24h(slot.iqama, key) : null;
    return { name: PRAYER_NAMES[key], time, iqama, isNext: false };
  });
}

function getTodayKey(): string {
  const d = new Date();
  const y = d.getFullYear();
  const m = String(d.getMonth() + 1).padStart(2, '0');
  const day = String(d.getDate()).padStart(2, '0');
  return `${y}-${m}-${day}`;
}

const dates = Object.keys(prayerTimesData) as string[];
const todayKey = getTodayKey();
const lookupKey = (prayerTimesData as Record<string, DayData>)[todayKey] ? todayKey : dates[0] ?? todayKey;
const dayData = (prayerTimesData as Record<string, DayData>)[lookupKey] ?? {};
const prayerTimes = dayDataToPrayerTimes(dayData);

function timeTo12h(t: string) {
  if (!t) return '';
  const [h, m] = t.split(':').map(Number);
  const h12 = h % 12 || 12;
  return `${h12}:${String(m).padStart(2, '0')}`;
}

function timeToPeriod(t: string) {
  if (!t) return '';
  const [h] = t.split(':').map(Number);
  return h >= 12 ? 'PM' : 'AM';
}
---

<!doctype html>
<html lang="en" class="daily-times-html">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <title>Daily Prayer Times | {siteDetails.metadata.title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Source+Sans+3:ital,wght@0,400;0,600;0,700;1,400&display=swap" rel="stylesheet" />
    <link rel="icon" type="image/png" href="/images/logo.png" />
  </head>
  <body class="daily-times-page">
    <main class="daily-times-main">
      <div class="daily-times-dates-row">
        <div class="daily-times-clock" aria-label="Current time">
          <p class="bigscreen-time-display daily-times-time-display">
            <span id="time-main">12:00</span><span class="bigscreen-time-seconds" id="time-period">PM</span>
          </p>
        </div>
        <div class="daily-times-dates">
          <p class="bigscreen-islamic-date daily-times-islamic-date" id="islamic-date">—</p>
          <p class="bigscreen-gregorian-date daily-times-gregorian-date" id="gregorian-date">—</p>
        </div>
      </div>
      <section class="daily-times-next-card bigscreen-card bigscreen-next-card">
        <h2 class="bigscreen-next-heading">Time remaining till</h2>
        <div class="bigscreen-next-body">
          <div class="bigscreen-next-left">
            <span class="bigscreen-next-name" id="next-prayer-name">Dhuhr</span>
            <span class="bigscreen-next-type" id="next-prayer-type">Adhan</span>
          </div>
          <div class="bigscreen-next-divider" aria-hidden="true"></div>
          <div class="bigscreen-next-right">
            <p class="bigscreen-next-time-display">
              <span class="bigscreen-next-time-main" id="countdown-main">00:45</span>
              <span class="bigscreen-next-time-seconds" id="countdown-seconds">12</span>
            </p>
          </div>
        </div>
      </section>

      <section class="daily-times-table-wrap" aria-label="Today's prayer times">
        <div class="daily-times-table">
          <div class="daily-times-row daily-times-header" role="row">
            <span class="daily-times-cell daily-times-cell-name" role="columnheader"></span>
            <span class="daily-times-cell daily-times-cell-adhan" role="columnheader">Adhan</span>
            <span class="daily-times-cell daily-times-cell-iqamah" role="columnheader">Iqamah</span>
          </div>
          {prayerTimes.map((p, i) => (
            <div class={`daily-times-row daily-times-data-row ${p.isNext ? 'bigscreen-prayer-card--next' : ''} ${!p.iqama ? 'daily-times-row--no-iqamah' : ''}`} id={`prayer-card-${i}`} data-prayer-index={i} role="row">
              <span class="daily-times-cell daily-times-cell-name" data-label="">
                <span class="bigscreen-prayer-name" id={`prayer-name-${i}`}>{p.name}</span>
              </span>
              <span class="daily-times-cell daily-times-cell-adhan" data-label="Adhan">
                <span class="daily-times-time">
                  <span id={`prayer-time-${i}`}>{timeTo12h(p.time)}</span>
                  <span class="bigscreen-prayer-time-period" id={`prayer-time-period-${i}`} aria-hidden="true">{timeToPeriod(p.time)}</span>
                </span>
              </span>
              <span class="daily-times-cell daily-times-cell-iqamah" data-label="Iqamah">
                <span class="daily-times-iqamah" id={`prayer-iqama-${i}`} style={p.iqama ? undefined : 'display:none'}>
                  <span class="bigscreen-prayer-iqama-time" id={`prayer-iqama-time-${i}`}>{p.iqama ? timeTo12h(p.iqama) : ''}</span>
                  <span class="daily-times-period" id={`prayer-iqama-period-${i}`} aria-hidden="true">{p.iqama ? timeToPeriod(p.iqama) : ''}</span>
                </span>
                <span class="daily-times-no-iqamah" id={`prayer-iqama-fallback-${i}`} style={p.iqama ? 'display:none' : undefined} aria-hidden="true">—</span>
              </span>
            </div>
          ))}
        </div>
      </section>
    </main>

    <script define:vars={{ prayerTimesDataJson: JSON.stringify(prayerTimesData) }}>
      (function () {
        function pad(n) {
          return String(n).padStart(2, '0');
        }
        function to24h(timeStr, key) {
          var parts = timeStr.split(':').map(Number);
          var h = parts[0], m = parts[1];
          if (['asr', 'maghrib', 'isha'].indexOf(key) !== -1 && h >= 1 && h <= 7) {
            return (h + 12) + ':' + pad(m);
          }
          return timeStr;
        }
        var PRAYER_KEYS = ['fajr', 'sunrise', 'dhuhr', 'asr', 'maghrib', 'isha'];
        var PRAYER_NAMES = { fajr: 'Fajr', sunrise: 'Sunrise', dhuhr: 'Dhuhr', asr: 'Asr', maghrib: 'Maghrib', isha: 'Isha' };
        function dayDataToPrayerTimes(dayData) {
          return PRAYER_KEYS.map(function (key) {
            var slot = dayData[key];
            if (!slot) return { name: PRAYER_NAMES[key], time: '00:00', iqama: null, isNext: false };
            return {
              name: PRAYER_NAMES[key],
              time: to24h(slot.start, key),
              iqama: slot.iqama ? to24h(slot.iqama, key) : null,
              isNext: false
            };
          });
        }
        function getTodayKey() {
          var d = new Date();
          return d.getFullYear() + '-' + pad(d.getMonth() + 1) + '-' + pad(d.getDate());
        }
        function formatTime12h(timeStr) {
          if (!timeStr) return '';
          var parts = timeStr.split(':').map(Number);
          var h = parts[0], m = parts[1];
          var h12 = h % 12 || 12;
          return h12 + ':' + pad(m);
        }
        function formatPeriod(timeStr) {
          if (!timeStr) return '';
          var h = parseInt(timeStr.split(':')[0], 10);
          return h >= 12 ? 'PM' : 'AM';
        }

        var timeMainEl = document.getElementById('time-main');
        var timePeriodEl = document.getElementById('time-period');
        var nextPrayerNameEl = document.getElementById('next-prayer-name');
        var nextPrayerTypeEl = document.getElementById('next-prayer-type');
        var countdownMainEl = document.getElementById('countdown-main');
        var countdownSecondsEl = document.getElementById('countdown-seconds');
        var gregorianDateEl = document.getElementById('gregorian-date');
        var islamicDateEl = document.getElementById('islamic-date');
        if (!nextPrayerNameEl || !nextPrayerTypeEl || !countdownMainEl || !countdownSecondsEl || !gregorianDateEl || !islamicDateEl) return;

        var dateOptions = { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' };
        var hijriFormatter = new Intl.DateTimeFormat('en-CA', { calendar: 'islamic-umalqura', day: 'numeric', month: 'long', year: 'numeric' });
        function ordinalDay(n) {
          var v = n % 100;
          return n + (v >= 11 && v <= 13 ? 'th' : (['th', 'st', 'nd', 'rd'][n % 10] || 'th'));
        }
        function formatHijri(date) {
          try {
            var parts = hijriFormatter.formatToParts(date);
            var day = '', month = '', year = '';
            for (var i = 0; i < parts.length; i++) {
              if (parts[i].type === 'day') day = parts[i].value;
              if (parts[i].type === 'month') month = parts[i].value;
              if (parts[i].type === 'year') year = parts[i].value;
            }
            return ordinalDay(parseInt(day, 10)) + ' ' + month + ', ' + year + ' AH';
          } catch (e) {
            return '—';
          }
        }

        var data = JSON.parse(prayerTimesDataJson || '{}');
        var dates = Object.keys(data);
        var todayKey = getTodayKey();
        var lookupKey = data[todayKey] ? todayKey : (dates[0] || todayKey);
        var dayData = data[lookupKey] || {};
        var prayers = dayDataToPrayerTimes(dayData);

        function getNextTarget(now) {
          var i;
          for (i = 0; i < prayers.length; i++) {
            var p = prayers[i];
            var adhan = p.time.split(':').map(Number);
            var adhanDate = new Date(now);
            adhanDate.setHours(adhan[0], adhan[1], 0, 0);
            if (now < adhanDate) {
              return { name: p.name, type: p.name === 'Sunrise' ? '' : 'Adhan', target: adhanDate };
            }
            if (p.iqama) {
              var iqama = p.iqama.split(':').map(Number);
              var iqamaDate = new Date(now);
              iqamaDate.setHours(iqama[0], iqama[1], 0, 0);
              if (now < iqamaDate) {
                return { name: p.name, type: 'Iqama', target: iqamaDate };
              }
            }
          }
          var first = prayers[0];
          if (first) {
            var adhan = first.time.split(':').map(Number);
            var next = new Date(now);
            next.setHours(adhan[0], adhan[1], 0, 0);
            next.setDate(next.getDate() + 1);
            return { name: first.name, type: 'Adhan', target: next };
          }
          return null;
        }

        function updateStrip() {
          var next = getNextTarget(new Date());
          var nextName = next ? next.name : null;
          for (var i = 0; i < prayers.length; i++) {
            prayers[i].isNext = prayers[i].name === nextName;
            var card = document.getElementById('prayer-card-' + i);
            var nameEl = document.getElementById('prayer-name-' + i);
            var timeEl = document.getElementById('prayer-time-' + i);
            var periodEl = document.getElementById('prayer-time-period-' + i);
            var iqamaEl = document.getElementById('prayer-iqama-' + i);
            if (card) {
              card.classList.toggle('bigscreen-prayer-card--next', prayers[i].isNext);
              card.classList.toggle('daily-times-row--no-iqamah', !prayers[i].iqama);
            }
            if (nameEl) nameEl.textContent = prayers[i].name.toUpperCase();
            if (timeEl) timeEl.textContent = formatTime12h(prayers[i].time);
            if (periodEl) periodEl.textContent = formatPeriod(prayers[i].time);
            if (iqamaEl) {
              var iqamaFallbackEl = document.getElementById('prayer-iqama-fallback-' + i);
              if (prayers[i].iqama) {
                var iqamaTimeEl = document.getElementById('prayer-iqama-time-' + i);
                var iqamaPeriodEl = document.getElementById('prayer-iqama-period-' + i);
                if (iqamaTimeEl) iqamaTimeEl.textContent = formatTime12h(prayers[i].iqama);
                if (iqamaPeriodEl) iqamaPeriodEl.textContent = formatPeriod(prayers[i].iqama);
                iqamaEl.style.display = '';
                if (iqamaFallbackEl) iqamaFallbackEl.style.display = 'none';
              } else {
                iqamaEl.style.display = 'none';
                if (iqamaFallbackEl) iqamaFallbackEl.style.display = '';
              }
            }
          }
        }

        var lastDateKey = lookupKey;
        updateStrip();

        function tick() {
          var d = new Date();
          if (timeMainEl && timePeriodEl) {
            var h = d.getHours();
            var m = d.getMinutes();
            var h12 = h % 12 || 12;
            timeMainEl.textContent = pad(h12) + ':' + pad(m);
            timePeriodEl.textContent = h >= 12 ? 'PM' : 'AM';
          }
          gregorianDateEl.textContent = d.toLocaleDateString('en-CA', dateOptions);
          islamicDateEl.textContent = formatHijri(d);
          var todayKeyNow = getTodayKey();
          if (todayKeyNow !== lastDateKey && data[todayKeyNow]) {
            lastDateKey = todayKeyNow;
            dayData = data[todayKeyNow];
            prayers = dayDataToPrayerTimes(dayData);
            updateStrip();
          }
          var next = getNextTarget(d);
          if (next) {
            nextPrayerNameEl.textContent = next.name;
            nextPrayerTypeEl.textContent = next.type;
            nextPrayerTypeEl.style.display = next.type ? '' : 'none';
            var diff = next.target - d;
            if (diff <= 0) {
              countdownMainEl.textContent = '00:00';
              countdownSecondsEl.textContent = '00';
            } else {
              var totalSecs = Math.floor(diff / 1000);
              var hours = Math.floor(totalSecs / 3600);
              var mins = Math.floor((totalSecs % 3600) / 60);
              var secs = totalSecs % 60;
              countdownMainEl.textContent = pad(hours) + ':' + pad(mins);
              countdownSecondsEl.textContent = pad(secs);
            }
          }
        }

        tick();
        var intervalId = setInterval(tick, 1000);
        function cleanup() {
          clearInterval(intervalId);
        }
        window.addEventListener('beforeunload', cleanup);
        window.addEventListener('pagehide', cleanup);
      })();
    </script>
  </body>
</html>

<style is:global>
  html.daily-times-html,
  html.daily-times-html body {
    margin: 0;
    padding: 0;
    height: 100%;
    min-height: 100dvh;
    width: 100%;
    max-width: 100vw;
    box-sizing: border-box;
  }
</style>

<style>
  :root {
    --bigscreen-bg: #0a0e1a;
    --bigscreen-card: #111827;
    --bigscreen-accent: #c9a959;
    --bigscreen-muted: #94a3b8;
  }

  .daily-times-page {
    margin: 0;
    font-family: 'Source Sans 3', ui-sans-serif, system-ui, sans-serif;
    display: flex;
    flex-direction: column;
    min-height: 100vh;
    min-height: 100dvh;
    height: 100%;
    width: 100%;
    max-width: 100vw;
    background-color: var(--bigscreen-bg);
    color: #e2e8f0;
    box-sizing: border-box;
    padding: env(safe-area-inset-top) env(safe-area-inset-right) env(safe-area-inset-bottom) env(safe-area-inset-left);
  }

  .bigscreen-card {
    background: var(--bigscreen-card);
    border-radius: 1rem;
    padding: clamp(0.75rem, 1.5vw, 1.25rem);
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .bigscreen-next-card {
    align-items: center;
    justify-content: center;
    gap: 0.5em;
  }

  .bigscreen-next-heading {
    font-size: clamp(1.3rem, 2.1vw, 1.7rem);
    font-weight: 500;
    color: var(--bigscreen-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin: 0 0 0.4em;
    text-align: center;
  }

  .bigscreen-next-body {
    display: flex;
    align-items: center;
    justify-content: space-around;
    gap: 0;
    width: 100%;
    min-height: 0;
  }

  .bigscreen-next-left {
    display: flex;
    align-items: baseline;
    justify-content: center;
    gap: clamp(0.5rem, 1vw, 0.85rem);
    flex: 1;
    padding-right: clamp(0.5rem, 1vw, 1rem);
  }

  .bigscreen-next-name {
    font-size: clamp(2.3rem, 4.2vw, 3.4rem);
    font-weight: 500;
    color: #fff;
    margin: 0;
  }

  .bigscreen-next-type {
    font-size: clamp(2.3rem, 4.2vw, 3.4rem);
    font-weight: 500;
    color: var(--bigscreen-muted);
    margin: 0;
  }

  .bigscreen-next-divider {
    width: 0.0625rem;
    min-height: 1.5em;
    background: rgba(148, 163, 184, 0.35);
    flex-shrink: 0;
  }

  .bigscreen-next-right {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    padding-left: clamp(0.5rem, 1vw, 1rem);
  }

  .bigscreen-next-time-display {
    display: flex;
    align-items: baseline;
    justify-content: center;
    gap: 0.08em;
    font-size: clamp(3.5rem, 7.5vw, 6rem);
    font-weight: 600;
    margin: 0;
    line-height: 1;
    letter-spacing: -0.02em;
  }

  .bigscreen-next-time-main {
    color: #fff;
  }

  .bigscreen-next-time-seconds {
    font-size: 0.5em;
    color: var(--bigscreen-accent);
    line-height: 1;
  }

  .bigscreen-prayer-card {
    background: var(--bigscreen-card);
    border-radius: 0.875rem;
    padding: clamp(0.5rem, 0.9vw, 0.85rem);
    text-align: center;
    position: relative;
    display: flex;
    flex-direction: column;
    justify-content: center;
    min-height: 0;
  }

  .bigscreen-prayer-card--next {
    background: var(--bigscreen-accent);
    color: #0a0e1a;
  }

  .bigscreen-prayer-name {
    font-size: clamp(1.2rem, 1.8vw, 1.55rem);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin: 0 0 0.65rem;
  }

  .daily-times-table-wrap .bigscreen-prayer-name {
    font-weight: 400;
  }

  .bigscreen-prayer-time {
    display: flex;
    align-items: baseline;
    justify-content: center;
    gap: 0.08em;
    font-size: clamp(2.4rem, 3.8vw, 3.4rem);
    font-weight: 500;
    margin: 0;
    line-height: 1;
  }

  .bigscreen-prayer-time-period {
    font-size: 0.65em;
    font-weight: 500;
    color: var(--bigscreen-muted);
    line-height: 1;
  }

  .bigscreen-prayer-card--next .bigscreen-prayer-time-period {
    color: rgba(61, 41, 20, 0.75);
  }

  .bigscreen-prayer-card--next .bigscreen-prayer-time {
    color: #0a0e1a;
  }

  .bigscreen-prayer-iqama {
    margin: 0.05rem 0 0;
  }

  .bigscreen-prayer-iqama-label {
    font-size: clamp(1.2rem, 1.7vw, 1.45rem);
    font-weight: 500;
    color: var(--bigscreen-muted);
  }

  .bigscreen-prayer-iqama-time {
    font-size: clamp(2rem, 3.1vw, 2.6rem);
    font-weight: 500;
    color: var(--bigscreen-accent);
    margin-left: 0.35em;
  }

  .bigscreen-prayer-card--next .bigscreen-prayer-iqama-label {
    color: #3d2914;
  }

  .bigscreen-prayer-card--next .bigscreen-prayer-iqama-time {
    color: #3d2914;
  }

  .daily-times-main {
    display: flex;
    flex-direction: column;
    flex: 1;
    min-height: 0;
    gap: clamp(0.75rem, 2dvh, 1.25rem);
    max-width: 38rem;
    margin: 0 auto;
    width: 100%;
    padding: clamp(0.75rem, 2dvh, 1.25rem) clamp(0.75rem, 3vw, 1.25rem);
    box-sizing: border-box;
    min-width: 0;
  }

  .daily-times-dates-row {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    width: 100%;
  }

  .daily-times-clock {
    flex-shrink: 0;
  }

  .daily-times-time-display {
    display: flex;
    align-items: baseline;
    gap: 0.08em;
    font-size: clamp(2rem, 6vw, 3.5rem);
    font-weight: 600;
    color: #e2e8f0;
    margin: 0;
    line-height: 1;
    letter-spacing: -0.02em;
  }

  .daily-times-time-display .bigscreen-time-seconds {
    font-size: 0.5em;
    color: var(--bigscreen-muted);
  }

  .daily-times-dates {
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
    line-height: 1.2;
    text-align: right;
  }

  .daily-times-islamic-date {
    font-size: clamp(1.05rem, 2vw, 1.4rem);
    color: var(--bigscreen-muted);
    margin: 0;
  }

  .daily-times-gregorian-date {
    font-size: clamp(1.15rem, 2.2vw, 1.55rem);
    font-weight: 600;
    color: #e2e8f0;
    margin: 0;
  }

  .daily-times-next-card {
    flex-shrink: 0;
    padding: clamp(1rem, 2.5dvh, 1.5rem) 1.25rem;
  }

  .daily-times-next-card .bigscreen-next-heading {
    font-size: clamp(0.95rem, 1.6vw, 1.3rem);
  }

  .daily-times-next-card .bigscreen-next-name,
  .daily-times-next-card .bigscreen-next-type {
    font-size: clamp(1.8rem, 6vw, 3.5dvh);
  }

  .daily-times-next-card .bigscreen-next-time-display {
    font-size: clamp(2.75rem, 9.5vw, 6dvh);
  }

  .daily-times-table-wrap {
    flex: 1;
    min-height: 0;
    display: flex;
    flex-direction: column;
    padding: 0;
  }

  .daily-times-table {
    display: flex;
    flex-direction: column;
    flex: 1;
    min-height: 0;
    gap: clamp(0.35rem, 1dvh, 0.6rem);
  }

  .daily-times-row {
    display: grid;
    grid-template-columns: 1fr minmax(4.5rem, auto) minmax(4.5rem, auto);
