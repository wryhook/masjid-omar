---
import { siteDetails } from '@/data/siteDetails';
import prayerTimesData from '@/data/prayer-times-feb-march-2026.json';

const PRAYER_KEYS = ['fajr', 'sunrise', 'dhuhr', 'asr', 'maghrib', 'isha'] as const;
const PRAYER_NAMES: Record<(typeof PRAYER_KEYS)[number], string> = {
  fajr: 'Fajr',
  sunrise: 'Sunrise',
  dhuhr: 'Dhuhr',
  asr: 'Asr',
  maghrib: 'Maghrib',
  isha: 'Isha',
};

/** Convert 12h afternoon times (asr, maghrib, isha) to 24h when hour is 1–7 */
function to24h(timeStr: string, key: string): string {
  const [h, m] = timeStr.split(':').map(Number);
  if (['asr', 'maghrib', 'isha'].includes(key) && h >= 1 && h <= 7) {
    return `${h + 12}:${String(m).padStart(2, '0')}`;
  }
  return timeStr;
}

type DayData = Record<string, { start: string; iqamah?: string }>;

function dayDataToPrayerTimes(dayData: DayData): { name: string; time: string; iqamah: string | null; isNext: boolean }[] {
  const list = PRAYER_KEYS.map((key) => {
    const slot = dayData[key];
    if (!slot) return { name: PRAYER_NAMES[key], time: '00:00', iqamah: null, isNext: false };
    const time = to24h(slot.start, key);
    const iqamah = slot.iqamah ? to24h(slot.iqamah, key) : null;
    return { name: PRAYER_NAMES[key], time, iqamah, isNext: false };
  });
  const now = new Date();
  let currentName: string | null = null;
  for (let i = 0; i < list.length; i++) {
    const [h, m] = list[i].time.split(':').map(Number);
    const adhanDate = new Date(now);
    adhanDate.setHours(h, m, 0, 0);
    if (now >= adhanDate) currentName = list[i].name;
    else break;
  }
  if (!currentName && list.length) currentName = list[list.length - 1].name;
  if (currentName) {
    for (let i = 0; i < list.length; i++) list[i].isNext = list[i].name === currentName;
  }
  return list;
}

function getTodayKey(): string {
  const d = new Date();
  const y = d.getFullYear();
  const m = String(d.getMonth() + 1).padStart(2, '0');
  const day = String(d.getDate()).padStart(2, '0');
  return `${y}-${m}-${day}`;
}

const dates = Object.keys(prayerTimesData) as string[];
const todayKey = getTodayKey();
const lookupKey = (prayerTimesData as Record<string, DayData>)[todayKey] ? todayKey : dates[0] ?? todayKey;
const dayData = (prayerTimesData as Record<string, DayData>)[lookupKey] ?? {};
const prayerTimes = dayDataToPrayerTimes(dayData);

function timeTo12h(t) {
  if (!t) return '';
  const [h, m] = t.split(':').map(Number);
  const h12 = h % 12 || 12;
  return `${h12}:${String(m).padStart(2, '0')}`;
}

function timeToPeriod(t) {
  if (!t) return '';
  const [h] = t.split(':').map(Number);
  return h >= 12 ? 'PM' : 'AM';
}

const classes = [
  { start: '5:00', title: 'Quran Tajweed', detail: 'Brother Ahmed Al-Masri • Main Hall', tag: 'DAILY', tagHighlight: false },
  { start: '7:00', title: 'Youth Halaqa', detail: 'Sheikh Omar Suleiman • Room B', tag: 'STARTING SOON', tagHighlight: true },
  { start: '8:30', title: 'Fiqh of Fasting', detail: 'Imam Zaid • Library', tag: 'SPECIAL', tagHighlight: false },
  { start: '9:45', title: 'Taraweeh Prayers', detail: 'Led by Qari Youssef • Main Prayer Hall', tag: 'RAMADAN', tagHighlight: false },
];

---

<!doctype html>
<html lang="en" class="bigscreen-html">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Big Screen | {siteDetails.metadata.title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Source+Sans+3:ital,wght@0,400;0,600;0,700;1,400&display=swap" rel="stylesheet" />
    <link rel="icon" type="image/png" href="/images/logo.png" />
  </head>
  <body class="bigscreen-page">
    <header class="bigscreen-header">
      <div class="bigscreen-header-left">
        <img src="/images/logo-white-bg.png" alt="" class="bigscreen-header-icon" />
        <h1 class="bigscreen-masjid-name">{siteDetails.metadata.title}</h1>
      </div>
      <div class="bigscreen-header-right">
        <p class="bigscreen-islamic-date" id="islamic-date">—</p>
        <p class="bigscreen-gregorian-date" id="gregorian-date">—</p>
      </div>
    </header>

    <main class="bigscreen-main">
      <aside class="bigscreen-left">
        <section class="bigscreen-card bigscreen-time-card">
          <p class="bigscreen-time-display">
            <span id="time-main">12:44</span><span class="bigscreen-time-seconds" id="time-period">PM</span>
          </p>
        </section>
        <section class="bigscreen-card bigscreen-next-card" id="next-card">
          <h3 class="bigscreen-next-heading" id="next-heading">Time remaining till</h3>
          <div class="bigscreen-next-body">
            <div class="bigscreen-next-left">
              <span class="bigscreen-next-name" id="next-prayer-name">Dhuhr</span> <span class="bigscreen-next-type" id="next-prayer-type">Adhan</span>
            </div>
            <div class="bigscreen-next-divider" id="next-divider" aria-hidden="true"></div>
            <div class="bigscreen-next-right" id="next-countdown-wrap">
              <p class="bigscreen-next-time-display">
                <span class="bigscreen-next-time-main" id="countdown-main">00:45</span><span class="bigscreen-next-time-seconds" id="countdown-seconds">12</span>
              </p>
            </div>
          </div>
        </section>
      </aside>

      <div class="bigscreen-right">
        <!-- Class schedule list (commented out for now)
        <section class="bigscreen-card bigscreen-classes-card">
          <h3 class="bigscreen-next-heading">Today's Classes</h3>
          <ul class="bigscreen-classes-list">
            {classes.map((c) => (
              <li class="bigscreen-class-row">
                <span class="bigscreen-class-time">{c.start}</span>
                <div class="bigscreen-class-info">
                  <span class="bigscreen-class-title">{c.title}</span>
                  <span class="bigscreen-class-detail">{c.detail}</span>
                </div>
                <span class={`bigscreen-class-tag ${c.tagHighlight ? 'bigscreen-class-tag--highlight' : ''}`}>{c.tag}</span>
              </li>
            ))}
          </ul>
        </section>
        -->
        <section class="bigscreen-card bigscreen-qr-card">
          <div class="bigscreen-qr-row">
            <h3 class="bigscreen-next-heading bigscreen-qr-heading">Donations</h3>
            <a href="/donate" class="bigscreen-qr-link" aria-label="Scan to open donations page">
              <img src="/images/donation-qr-code.png" alt="Donations QR code" class="bigscreen-qr-img" width="120" height="120" />
            </a>
          </div>
        </section>
        <section class="bigscreen-card bigscreen-qr-card">
          <div class="bigscreen-qr-row">
            <h3 class="bigscreen-next-heading bigscreen-qr-heading">Weekly class schedule</h3>
            <a href="/class-schedule" class="bigscreen-qr-link" aria-label="Scan to open weekly class schedule">
              <img src="/images/class-schedule-qr-code.png" alt="Class schedule QR code" class="bigscreen-qr-img" width="120" height="120" />
            </a>
          </div>
        </section>
      </div>
    </main>

    <section class="bigscreen-prayer-grid">
      {prayerTimes.map((p, i) => (
        <div class="bigscreen-prayer-card" id={`prayer-card-${i}`} data-prayer-index={i}>
          <p class="bigscreen-prayer-name" id={`prayer-name-${i}`}>{p.name.toUpperCase()}</p>
          <p class="bigscreen-prayer-time"><span id={`prayer-time-${i}`}>{timeTo12h(p.time)}</span><span class="bigscreen-prayer-time-period" id={`prayer-time-period-${i}`} aria-hidden="true">{timeToPeriod(p.time)}</span></p>
          <p class="bigscreen-prayer-iqamah" id={`prayer-iqamah-${i}`} style={p.iqamah ? undefined : 'display:none'}>{p.iqamah ? (<><span class="bigscreen-prayer-iqamah-label">Iqamah </span><span class="bigscreen-prayer-iqamah-time" id={`prayer-iqamah-time-${i}`}>{timeTo12h(p.iqamah)}</span></>) : ''}</p>
        </div>
      ))}
    </section>

    <script define:vars={{ prayerTimesDataJson: JSON.stringify(prayerTimesData) }}>
      (function () {
        function pad(n) {
          return String(n).padStart(2, '0');
        }
        function to24h(timeStr, key) {
          var parts = timeStr.split(':').map(Number);
          var h = parts[0], m = parts[1];
          if (['asr', 'maghrib', 'isha'].indexOf(key) !== -1 && h >= 1 && h <= 7) {
            return (h + 12) + ':' + pad(m);
          }
          return timeStr;
        }
        var PRAYER_KEYS = ['fajr', 'sunrise', 'dhuhr', 'asr', 'maghrib', 'isha'];
        var PRAYER_NAMES = { fajr: 'Fajr', sunrise: 'Sunrise', dhuhr: 'Dhuhr', asr: 'Asr', maghrib: 'Maghrib', isha: 'Isha' };
        function dayDataToPrayerTimes(dayData) {
          return PRAYER_KEYS.map(function (key) {
            var slot = dayData[key];
            if (!slot) return { name: PRAYER_NAMES[key], time: '00:00', iqamah: null, isNext: false };
            return {
              name: PRAYER_NAMES[key],
              time: to24h(slot.start, key),
              iqamah: slot.iqamah ? to24h(slot.iqamah, key) : null,
              isNext: false
            };
          });
        }
        function getTodayKey() {
          var d = new Date();
          return d.getFullYear() + '-' + pad(d.getMonth() + 1) + '-' + pad(d.getDate());
        }
        function formatTime12h(timeStr) {
          if (!timeStr) return '';
          var parts = timeStr.split(':').map(Number);
          var h = parts[0], m = parts[1];
          var h12 = h % 12 || 12;
          return h12 + ':' + pad(m);
        }
        function formatPeriod(timeStr) {
          if (!timeStr) return '';
          var h = parseInt(timeStr.split(':')[0], 10);
          return h >= 12 ? 'PM' : 'AM';
        }

        var timeMain = document.getElementById('time-main');
        var timePeriod = document.getElementById('time-period');
        var gregorianDate = document.getElementById('gregorian-date');
        var islamicDateEl = document.getElementById('islamic-date');
        var nextCardEl = document.getElementById('next-card');
        var nextHeadingEl = document.getElementById('next-heading');
        var nextPrayerNameEl = document.getElementById('next-prayer-name');
        var nextPrayerTypeEl = document.getElementById('next-prayer-type');
        var nextDividerEl = document.getElementById('next-divider');
        var countdownWrapEl = document.getElementById('next-countdown-wrap');
        var countdownMainEl = document.getElementById('countdown-main');
        var countdownSecondsEl = document.getElementById('countdown-seconds');
        if (!timeMain || !timePeriod || !gregorianDate || !islamicDateEl || !nextCardEl || !nextHeadingEl || !nextPrayerNameEl || !nextPrayerTypeEl || !nextDividerEl || !countdownWrapEl || !countdownMainEl || !countdownSecondsEl) return;

        var data = JSON.parse(prayerTimesDataJson || '{}');
        var dates = Object.keys(data);
        var todayKey = getTodayKey();
        var lookupKey = data[todayKey] ? todayKey : (dates[0] || todayKey);
        var dayData = data[lookupKey] || {};
        var prayers = dayDataToPrayerTimes(dayData);
        var dateOptions = { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' };
        var hijriFormatter = new Intl.DateTimeFormat('en-CA', { calendar: 'islamic-umalqura', day: 'numeric', month: 'long', year: 'numeric' });

        function ordinalDay(n) {
          var v = n % 100;
          return n + (v >= 11 && v <= 13 ? 'th' : (['th', 'st', 'nd', 'rd'][n % 10] || 'th'));
        }

        function formatHijri(date) {
          try {
            var parts = hijriFormatter.formatToParts(date);
            var day = '', month = '', year = '';
            for (var i = 0; i < parts.length; i++) {
              if (parts[i].type === 'day') day = parts[i].value;
              if (parts[i].type === 'month') month = parts[i].value;
              if (parts[i].type === 'year') year = parts[i].value;
            }
            return ordinalDay(parseInt(day, 10)) + ' ' + month + ', ' + year + ' AH';
          } catch (e) {
            return '—';
          }
        }

        function getNextTarget(now) {
          var i;
          for (i = 0; i < prayers.length; i++) {
            var p = prayers[i];
            var adhan = p.time.split(':').map(Number);
            var adhanDate = new Date(now);
            adhanDate.setHours(adhan[0], adhan[1], 0, 0);
            if (now < adhanDate) {
              return { name: p.name, type: p.name === 'Sunrise' ? '' : 'Adhan', target: adhanDate };
            }
            if (p.iqamah) {
              var iqamah = p.iqamah.split(':').map(Number);
              var iqamahDate = new Date(now);
              iqamahDate.setHours(iqamah[0], iqamah[1], 0, 0);
              if (now < iqamahDate) {
                return { name: p.name, type: 'Iqamah', target: iqamahDate };
              }
            }
          }
          var first = prayers[0];
          if (first) {
            var adhan = first.time.split(':').map(Number);
            var next = new Date(now);
            next.setHours(adhan[0], adhan[1], 0, 0);
            next.setDate(next.getDate() + 1);
            return { name: first.name, type: 'Adhan', target: next };
          }
          return null;
        }

        function getCurrentPrayer(now) {
          if (prayers.length === 0) return null;
          var lastPassed = null;
          for (var i = 0; i < prayers.length; i++) {
            var p = prayers[i];
            var adhan = p.time.split(':').map(Number);
            var adhanDate = new Date(now);
            adhanDate.setHours(adhan[0], adhan[1], 0, 0);
            if (now >= adhanDate) {
              lastPassed = p;
            } else {
              break;
            }
          }
          if (!lastPassed) lastPassed = prayers[prayers.length - 1];
          return lastPassed ? { name: lastPassed.name } : null;
        }

        function getOngoingPrayer(now) {
          var fiveMinMs = 5 * 60 * 1000;
          for (var i = 0; i < prayers.length; i++) {
            var p = prayers[i];
            if (p.name === 'Sunrise' || !p.iqamah) continue;
            var iqamah = p.iqamah.split(':').map(Number);
            var iqamahDate = new Date(now);
            iqamahDate.setHours(iqamah[0], iqamah[1], 0, 0);
            var endOngoing = iqamahDate.getTime() + fiveMinMs;
            if (now.getTime() >= iqamahDate.getTime() && now.getTime() < endOngoing) {
              return { name: p.name };
            }
          }
          return null;
        }

        function getPreviewOngoingPrayer() {
          if (document.location.search.indexOf('preview=ongoing') === -1) return null;
          for (var i = 0; i < prayers.length; i++) {
            var p = prayers[i];
            if (p.name !== 'Sunrise' && p.iqamah) return { name: p.name };
          }
          return { name: 'Dhuhr' };
        }

        var stripCardEls = [];
        var stripNameEls = [];
        var stripTimeEls = [];
        var stripPeriodEls = [];
        var stripIqamahEls = [];
        var stripIqamahTimeEls = [];
        for (var si = 0; si < 6; si++) {
          stripCardEls.push(document.getElementById('prayer-card-' + si));
          stripNameEls.push(document.getElementById('prayer-name-' + si));
          stripTimeEls.push(document.getElementById('prayer-time-' + si));
          stripPeriodEls.push(document.getElementById('prayer-time-period-' + si));
          stripIqamahEls.push(document.getElementById('prayer-iqamah-' + si));
          stripIqamahTimeEls.push(document.getElementById('prayer-iqamah-time-' + si));
        }

        function updateStrip() {
          var current = getCurrentPrayer(new Date());
          var currentName = current ? current.name : null;
          for (var i = 0; i < prayers.length; i++) {
            prayers[i].isNext = prayers[i].name === currentName;
            var card = stripCardEls[i];
            var nameEl = stripNameEls[i];
            var timeEl = stripTimeEls[i];
            var periodEl = stripPeriodEls[i];
            var iqamahEl = stripIqamahEls[i];
            if (nameEl) nameEl.textContent = prayers[i].name.toUpperCase();
            if (timeEl) timeEl.textContent = formatTime12h(prayers[i].time);
            if (periodEl) periodEl.textContent = formatPeriod(prayers[i].time);
            if (iqamahEl) {
              if (prayers[i].iqamah) {
                var iqamahTimeEl = stripIqamahTimeEls[i];
                if (iqamahTimeEl) iqamahTimeEl.textContent = formatTime12h(prayers[i].iqamah);
                iqamahEl.style.display = '';
              } else {
                iqamahEl.style.display = 'none';
              }
            }
          }
        }

        var lastDateKey = lookupKey;
        updateStrip();

        var tickTimeoutId = null;

        function tick() {
          var d = new Date();
          var todayKeyNow = getTodayKey();
          if (todayKeyNow !== lastDateKey && data[todayKeyNow]) {
            lastDateKey = todayKeyNow;
            dayData = data[todayKeyNow];
            prayers = dayDataToPrayerTimes(dayData);
            updateStrip();
          }
          var h = d.getHours();
          var m = d.getMinutes();
          var h12 = h % 12 || 12;
          timeMain.textContent = pad(h12) + ':' + pad(m);
          timePeriod.textContent = h >= 12 ? 'PM' : 'AM';
          gregorianDate.textContent = d.toLocaleDateString('en-CA', dateOptions);
          islamicDateEl.textContent = formatHijri(d);

          var ongoing = getPreviewOngoingPrayer() || getOngoingPrayer(d);
          if (ongoing) {
            nextCardEl.classList.add('bigscreen-next-card--ongoing');
            nextHeadingEl.textContent = 'Ongoing';
            nextPrayerNameEl.textContent = ongoing.name;
            nextPrayerTypeEl.textContent = 'Jamaah';
            nextPrayerTypeEl.style.display = '';
            nextDividerEl.style.display = 'none';
            countdownWrapEl.style.display = 'none';
            var currentName = ongoing.name;
            for (var i = 0; i < prayers.length; i++) {
              var card = stripCardEls[i];
              if (card) card.classList.toggle('bigscreen-prayer-card--next', prayers[i].name === currentName);
            }
          } else {
            nextCardEl.classList.remove('bigscreen-next-card--ongoing');
            var next = getNextTarget(d);
            nextHeadingEl.textContent = 'Time remaining till';
            nextDividerEl.style.display = '';
            var current = getCurrentPrayer(d);
            var currentName = current ? current.name : null;
            for (var i = 0; i < prayers.length; i++) {
              var card = stripCardEls[i];
              if (card) card.classList.toggle('bigscreen-prayer-card--next', prayers[i].name === currentName);
            }
            if (next) {
              nextPrayerNameEl.textContent = next.name;
              nextPrayerTypeEl.textContent = next.type;
              nextPrayerTypeEl.style.display = next.type ? '' : 'none';
              countdownWrapEl.style.display = '';
              var diff = next.target - d;
              if (diff <= 0) {
                countdownMainEl.textContent = '00:00';
                countdownSecondsEl.textContent = '00';
              } else {
                var totalSecs = Math.floor(diff / 1000);
                var hours = Math.floor(totalSecs / 3600);
                var mins = Math.floor((totalSecs % 3600) / 60);
                var secs = totalSecs % 60;
                countdownMainEl.textContent = pad(hours) + ':' + pad(mins);
                countdownSecondsEl.textContent = pad(secs);
              }
            }
          }
        }

        function scheduleTick() {
          var nowMs = Date.now();
          tick();
          var delay = 1000 - (nowMs % 1000);
          if (delay < 50) delay = 1000;
          tickTimeoutId = setTimeout(function runTick() {
            tickTimeoutId = null;
            scheduleTick();
          }, delay);
        }
        scheduleTick();
        function cleanup() {
          if (tickTimeoutId != null) {
            clearTimeout(tickTimeoutId);
            tickTimeoutId = null;
          }
        }
        window.addEventListener('beforeunload', cleanup);
        window.addEventListener('pagehide', cleanup);
      })();
    </script>
  </body>
</html>

<style is:global>
  html.bigscreen-html,
  html.bigscreen-html body {
    margin: 0;
    padding: 0;
    height: 100%;
    min-height: 100vh;
    min-height: 100dvh;
    width: 100%;
    max-width: 100vw;
    overflow: hidden;
    box-sizing: border-box;
  }
</style>

<style>
  .bigscreen-page {
    margin: 0;
    font-family: 'Source Sans 3', ui-sans-serif, system-ui, sans-serif;
    height: 100%;
    min-height: 100vh;
    min-height: 100dvh;
    width: 100%;
    max-width: 100vw;
    background-color: #0a0e1a;
    color: #e2e8f0;
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
    padding: clamp(0.75rem, 1.5vw, 1.5rem);
    gap: clamp(0.5rem, 1.2vw, 1rem);
    overflow: hidden;
  }

  :root {
    --bigscreen-bg: #0a0e1a;
    --bigscreen-card: #111827;
    --bigscreen-accent: #c9a959;
    --bigscreen-accent-dim: #8b6914;
    --bigscreen-muted: #94a3b8;
  }

  .bigscreen-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 1rem;
    flex-shrink: 0;
  }

  .bigscreen-header-left {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .bigscreen-header-icon {
    width: clamp(3.5rem, 7vw, 5.25rem);
    height: auto;
    display: block;
    border-radius: 0.5rem;
  }

  .bigscreen-masjid-name {
    font-size: clamp(1.6rem, 3.6vw, 4.5rem);
    font-weight: 600;
    margin: 0;
    color: #fff;
  }

  .bigscreen-header-right {
    text-align: right;
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
    line-height: 1.2;
  }

  .bigscreen-islamic-date {
    font-size: clamp(1.3rem, 2.5vw, 2.9rem);
    color: #e2e8f0;
    margin: 0;
    line-height: 1.2;
  }

  .bigscreen-gregorian-date {
    font-size: clamp(1.35rem, 2.5vw, 3.15rem);
    font-weight: 600;
    color: #fff;
    margin: 0;
    line-height: 1.2;
  }

  .bigscreen-main {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(0.75rem, 1.5vw, 1.25rem);
    flex: 1;
    min-height: 0;
    overflow: hidden;
  }

  @media (max-width: 56.25em) {
    .bigscreen-main {
      grid-template-columns: 1fr;
    }
  }

  .bigscreen-left {
    display: flex;
    flex-direction: column;
    gap: clamp(0.5rem, 1.2vw, 1rem);
    min-height: 0;
  }

  .bigscreen-right {
    display: flex;
    flex-direction: column;
    gap: clamp(0.5rem, 1.2vw, 1rem);
    min-height: 0;
  }

  .bigscreen-card {
    background: var(--bigscreen-card);
    border-radius: 1rem;
    padding: clamp(0.75rem, 1.5vw, 1.25rem);
