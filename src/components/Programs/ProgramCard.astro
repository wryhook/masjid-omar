---
interface Props {
  imgUrl: string;
  heading: string;
  title: string;
  description: string;
  note: string;
  timing: string;
}

const { imgUrl, heading, title, description, note, timing } = Astro.props;
---

<div class="flex flex-col sm:flex-row max-w-5xl mx-auto">
  <div class="w-full sm:w-1/2 relative">
    <div
      class="bg-cover bg-center bg-no-repeat w-full aspect-[1/1]"
      style={`background-image: url(${imgUrl})`}
    ></div>
  </div>

  <div class="w-full sm:w-1/2 flex flex-col justify-center bg-[#fff9f5] p-12">
    <p class="text-lg">{heading}</p>
    <h2 class="text-3xl font-semibold text-gray-800 mt-5">{title}</h2>
    <p class="mt-3">{description}</p>
    <p class="italic mt-6">{note}</p>
    <p class="text-xl font-semibold mt-6">{timing}</p>
  </div>
</div>
