---
import Header from '@/components/Header';
import { siteDetails } from '@/data/siteDetails';

interface Props {
  title?: string;
  description?: string;
}

const { title = siteDetails.metadata.title, description = siteDetails.metadata.description } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={siteDetails.siteUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={`${siteDetails.siteUrl.replace(/\/$/, '')}/images/og-image.jpg`} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="675" />
    <meta property="og:image:alt" content={siteDetails.siteName} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${siteDetails.siteUrl.replace(/\/$/, '')}/images/twitter-image.jpg`} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Source+Sans+3:ital,wght@0,400;0,600;0,700;1,400&display=swap" rel="stylesheet" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    {siteDetails.googleAnalyticsId && (
      <>
        <script is:inline src={`https://www.googletagmanager.com/gtag/js?id=${siteDetails.googleAnalyticsId}`}></script>
        <script is:inline define:vars={{ gaId: siteDetails.googleAnalyticsId }}>
          {`window.dataLayer = window.dataLayer || []; function gtag(){dataLayer.push(arguments);} gtag('js', new Date()); gtag('config', gaId);`}
        </script>
      </>
    )}
  </head>
  <body class="antialiased">
    <Header client:load />
    <main>
      <slot />
    </main>
  </body>
</html>

<style is:global>
  @import '../styles/globals.css';
</style>
